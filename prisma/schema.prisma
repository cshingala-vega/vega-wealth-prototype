generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions           Session[]
  memberships        OrganizationMember[]
  ingestionRuns      IngestionRun[]
  reconciliationRuns ReconciliationRun[]
  caseComms          CaseComm[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Multi-tenant ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members            OrganizationMember[]
  funds              Fund[]
  distributors       Distributor[]
  transferAgents     TransferAgent[]
  mappingTemplates   ColumnMappingTemplate[]
  ingestionRuns      IngestionRun[]
  workbenchOrders    WorkbenchOrder[]
  reconciliationRuns ReconciliationRun[]
  exceptions         Exception[]
  cases              Case[]
}

model OrganizationMember {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole          @default(MEMBER)
  joinedAt       DateTime         @default(now())

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── Ingestion Reference Data ─────────────────────────────────────────────────

model Fund {
  id             String   @id @default(cuid())
  name           String
  aliases        String[]
  shareClasses   String[]
  organizationId String
  createdAt      DateTime @default(now())

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reconciliationRuns ReconciliationRun[]

  @@index([organizationId])
}

model Distributor {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime @default(now())

  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ingestionRuns    IngestionRun[]
  mappingTemplates ColumnMappingTemplate[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model TransferAgent {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime @default(now())

  organization       Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reconciliationRuns ReconciliationRun[]
  mappingTemplates   ColumnMappingTemplate[]

  @@unique([name, organizationId])
  @@index([organizationId])
}

model ColumnMappingTemplate {
  id               String    @id @default(cuid())
  distributorId    String?
  transferAgentId  String?
  organizationId   String
  name             String
  mappingJson      Json
  isDefault        Boolean   @default(false)
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())

  distributor        Distributor?        @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  transferAgent      TransferAgent?      @relation(fields: [transferAgentId], references: [id], onDelete: Cascade)
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ingestionRuns      IngestionRun[]
  reconciliationRuns ReconciliationRun[]

  @@index([distributorId])
  @@index([transferAgentId])
  @@index([organizationId])
}

// ─── Ingestion Run ─────────────────────────────────────────────────────────────

enum IngestionStatus {
  PENDING
  MAPPING
  REVIEW
  COMMITTED
}

model IngestionRun {
  id               String          @id @default(cuid())
  distributorId    String
  organizationId   String
  userId           String
  closeCycle       DateTime
  fileName         String
  detectedColumns  String[]
  previewRows      Json?
  status           IngestionStatus @default(PENDING)
  rowsProcessed    Int             @default(0)
  rowsIngested     Int             @default(0)
  rowsExcluded     Int             @default(0)
  rowsFlagged      Int             @default(0)
  aiQualityScore   Float?
  aiSummary        String?
  templateId       String?
  committedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  distributor  Distributor            @relation(fields: [distributorId], references: [id])
  organization Organization           @relation(fields: [organizationId], references: [id])
  user         User                   @relation(fields: [userId], references: [id])
  template     ColumnMappingTemplate? @relation(fields: [templateId], references: [id])
  orders       WorkbenchOrder[]

  @@index([organizationId])
  @@index([distributorId])
  @@index([userId])
}

// ─── Workbench Order ──────────────────────────────────────────────────────────

model WorkbenchOrder {
  id              String   @id @default(cuid())
  runId           String
  organizationId  String
  transactionId   String
  transactionType String
  amount          Decimal
  effectiveDate   DateTime
  fundName        String?
  shareClass      String?
  investorName    String?
  status          String?
  currency        String?
  aiFlags         Json?
  isExcluded      Boolean  @default(false)
  createdAt       DateTime @default(now())

  run          IngestionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  exceptions   Exception[]

  @@index([runId])
  @@index([organizationId])
}

// ─── Reconciliation ───────────────────────────────────────────────────────────

enum ReconciliationStatus {
  PENDING
  MAPPING
  RUNNING
  COMPLETE
}

model ReconciliationRun {
  id                String               @id @default(cuid())
  organizationId    String
  transferAgentId   String
  fundId            String
  userId            String
  closeCycle        DateTime
  fileName          String
  detectedColumns   String[]
  previewRows       Json?
  status            ReconciliationStatus @default(PENDING)
  taRowCount        Int                  @default(0)
  portalOrderCount  Int                  @default(0)
  matchedCount      Int                  @default(0)
  issuesCount       Int                  @default(0)
  matchRate         Float?
  aiNarrative       String?
  templateId        String?
  completedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  organization  Organization           @relation(fields: [organizationId], references: [id])
  transferAgent TransferAgent          @relation(fields: [transferAgentId], references: [id])
  fund          Fund                   @relation(fields: [fundId], references: [id])
  user          User                   @relation(fields: [userId], references: [id])
  template      ColumnMappingTemplate? @relation(fields: [templateId], references: [id])
  exceptions    Exception[]
  deltas        RunDelta[]

  @@index([organizationId])
  @@index([transferAgentId])
  @@index([fundId])
}

enum ExceptionType {
  STAGE_MISMATCH
  AMOUNT_FIELD_DIFF
  MISSING_IN_PORTAL
  MISSING_IN_TA
}

enum ExceptionResolution {
  OPEN
  COMMUNICATED
  RESOLVED
  ESCALATED
}

model Exception {
  id               String              @id @default(cuid())
  runId            String
  organizationId   String
  exceptionType    ExceptionType
  taTxnId          String?
  workbenchOrderId String?
  amount           Decimal
  fundName         String?
  fieldDiffs       Json?
  aiPriority       Int                 @default(5)
  aiRootCause      String?
  isPersistent     Boolean             @default(false)
  firstSeenRunId   String?
  firstSeenAt      DateTime?
  resolution       ExceptionResolution @default(OPEN)
  resolutionReason String?
  resolutionNote   String?
  createdAt        DateTime            @default(now())

  run            ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  organization   Organization      @relation(fields: [organizationId], references: [id])
  workbenchOrder WorkbenchOrder?   @relation(fields: [workbenchOrderId], references: [id])
  caseItems      CaseItem[]

  @@index([runId])
  @@index([organizationId])
  @@index([resolution])
}

model RunDelta {
  id                   String  @id @default(cuid())
  runId                String
  previousRunId        String?
  newExceptions        Int     @default(0)
  resolvedExceptions   Int     @default(0)
  persistentExceptions Int     @default(0)
  aiDeltaSummary       String?

  run ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

model Case {
  id               String   @id @default(cuid())
  organizationId   String
  title            String
  counterpartyType String
  counterpartyId   String
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  items        CaseItem[]
  comms        CaseComm[]

  @@index([organizationId])
}

model CaseItem {
  id          String @id @default(cuid())
  caseId      String
  exceptionId String

  case_     Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  exception Exception @relation(fields: [exceptionId], references: [id])

  @@index([caseId])
  @@index([exceptionId])
}

enum CommDirection {
  OUTBOUND
  INBOUND
}

model CaseComm {
  id        String        @id @default(cuid())
  caseId    String
  direction CommDirection
  subject   String
  body      String
  sentAt    DateTime      @default(now())
  sentBy    String

  case_ Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user  User @relation(fields: [sentBy], references: [id])

  @@index([caseId])
}
